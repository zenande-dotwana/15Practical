import java.io.*;
import java.util.*;

public class Anagrams {
    
    public static void main(String[] args) {
        
        // Creating a dictionary/hashmap to store anagrams
        Map<String, List<String>> anagramMap = new HashMap<>();
        
        try {
            // Read the file
            BufferedReader reader = new BufferedReader(new FileReader("ulysses.text"));
            String line;
            
            // Process each line in the file
            while ((line = reader.readLine()) != null) {
                // Split line into words
                String[] words = line.split("\\s+");
                
                for (String word : words) {
                    // Clean and process each word
                    processWord(word, anagramMap);
                }
            }
            reader.close();

            // Print anagrams to the console
            printAnagrams(anagramMap);
            
            // Generate LaTeX file
            generateLatexFile(anagramMap);
            
        } catch (FileNotFoundException e) {
            System.err.println("Error: ulysses.text file not found!");
            e.printStackTrace();
        } catch (IOException e) {
            System.err.println("Error reading file!");
            e.printStackTrace();
        }
    }
    
    private static void processWord(String word, Map<String, List<String>> anagramMap) {
        // Clean the word - remove all punctuation but keep apostrophes
        String cleaned = cleanWord(word);
        
        if (cleaned.length() > 0) {
            // Convert the cleaned word to lowercase
            cleaned = cleaned.toLowerCase();
            
            // Create signature (alphabetized version)
            String signature = alphabetize(cleaned);
            
            // Add to the map
            if (!anagramMap.containsKey(signature)) {
                List<String> wordList = new ArrayList<>();
                wordList.add(cleaned);
                anagramMap.put(signature, wordList);
            } else {
                List<String> wordList = anagramMap.get(signature);
                if (!wordList.contains(cleaned)) { // Avoid duplicates
                    wordList.add(cleaned);
                }
            }
        }
    }
    private static String cleanWord(String word) {
        // Remove punctuation but keep apostrophes
        // This regex keeps letters, apostrophes, and hyphens, removes everything else
        return word.replaceAll("[^a-zA-Z']", "").trim();
    }
    
    private static String alphabetize(String word) {
        // Converting string to char array and sort it
        char[] chars = word.toCharArray();
        Arrays.sort(chars);
        return new String(chars);
    }
    
    private static void printAnagrams(Map<String, List<String>> anagramMap) {
        System.out.println("\n=== ANAGRAMS FOUND ===\n");
        
        // Sort keys for consistent output
        List<String> sortedKeys = new ArrayList<>(anagramMap.keySet());
        Collections.sort(sortedKeys);
        
        for (String key : sortedKeys) {
            List<String> words = anagramMap.get(key);
            // Only show groups with at least 2 words (actual anagrams)
            if (words.size() >= 2) {
                System.out.println(key + ": " + words);
            }
        }
    }
    
    private static void generateLatexFile(Map<String, List<String>> anagramMap) {
        try {
            BufferedWriter writer = new BufferedWriter(new FileWriter("theAnagrams.tex"));
            
            // Write LaTeX header
            writer.write("\\documentclass{article}\n");
            writer.write("\\usepackage{geometry}\n");
            writer.write("\\geometry{a4paper, margin=1in}\n");
            writer.write("\\begin{document}\n");
            writer.write("\\title{Anagrams from Ulysses}\n");
            writer.write("\\author{Generated by Anagrams.java}\n");
            writer.write("\\maketitle\n\n");
            writer.write("\\begin{description}\n");

            // Sort keys for consistent output
            List<String> sortedKeys = new ArrayList<>(anagramMap.keySet());
            Collections.sort(sortedKeys);
            
            // Write anagram entries
            for (String key : sortedKeys) {
                List<String> words = anagramMap.get(key);
                // Only include the groups with at least 2 words
                if (words.size() >= 2) {
                    // Sort the words alphabetically
                    Collections.sort(words);
                    
                    writer.write("  \\item[" + key + "] ");
                    for (int i = 0; i < words.size(); i++) {
                        writer.write(words.get(i));
                        if (i < words.size() - 1) {
                            writer.write(", ");
                        }
                    }
                    writer.write("\n");
                }
            }
            
            writer.write("\\end{description}\n");
            writer.write("\\end{document}\n");
            
            writer.close();
            System.out.println("\nLaTeX file 'theAnagrams.tex' generated successfully!");
            
        } catch (IOException e) {
            System.err.println("Error generating LaTeX file!");
            e.printStackTrace();
        }
    }
}
